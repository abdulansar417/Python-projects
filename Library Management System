class Book:
    def __init__(self, title, author):
        self.title = title
        self.author = author
        self.avail = True

    def __str__(self):
        status = "Available" if self.avail else "Not Available"
        return f"{self.title} by {self.author} is {status}"

class Library:
    def __init__(self):
        self.books = []

    def add_book(self, book):
        self.books.append(book)

    def __str__(self):
        result = ""

        for book in self.books:
            result += str(book) + "\n"

        return result

library = Library()
book1 = Book("Puzzle Master", "Austin")
book2 = Book("Race Champion", "Oliver")
library.add_book(book1)
library.add_book(book2)
print(library)
